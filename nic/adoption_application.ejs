<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Adoption Application</title>
</head>
<body>

  <h1>Pet Adoption Application</h1>

  <% if (typeof successMsg !== 'undefined' && successMsg) { %>
    <p><%= successMsg %></p>
  <% } %>
  <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
    <p><%= errorMsg %></p>
  <% } %>

  <form action="/adoption/apply" method="POST"></form>

    <h2>1. Applicant's Information</h2>

    <label for="fullName">Full Name *</label><br>
    <input type="text" id="fullName" name="fullName"
      value="<%= typeof user !== 'undefined' ? user.fullName : '' %>"
      placeholder="e.g. Jane Tan" required /><br><br>

    <label for="email">Email Address *</label><br>
    <input type="email" id="email" name="email"
      value="<%= typeof user !== 'undefined' ? user.email : '' %>"
      placeholder="jane@email.com" required /><br><br>

    <label for="phone">Phone Number *</label><br>
    <input type="tel" id="phone" name="phone"
      value="<%= typeof user !== 'undefined' ? user.phone : '' %>"
      placeholder="+65 9123 4567" required /><br><br>

    <label for="age">Age *</label><br>
    <input type="number" id="age" name="age" min="18" max="99"
      placeholder="21" required /><br><br>

    <label for="address">Home Address *</label><br>
    <input type="text" id="address" name="address"
      placeholder="Block 12, Ang Mo Kio Ave 3, #05-22" required /><br><br>

    <label for="housingType">Housing Type *</label><br>
    <select id="housingType" name="housingType" required>
      <option value="" disabled selected>Select your housing type</option>
      <option value="hdb">HDB Flat</option>
      <option value="condo">Condominium</option>
      <option value="landed">Landed Property</option>
      <option value="other">Other</option>
    </select><br><br>


    <h2>2. Pet Preference</h2>

    <label for="petId">Preferred Pet *</label><br>
    <select id="petId" name="petId" required>
      <option value="" disabled selected>Select a pet</option>
      <% pets.forEach(function(pet) { %>
        <option value="<%= pet.id %>"
          <%= (typeof selectedPetId !== 'undefined' && selectedPetId == pet.id) ? 'selected' : '' %>>
          <%= pet.name %> — <%= pet.species %>, <%= pet.age %> yr(s)
        </option>
      <% }); %>
    </select><br><br>

    <label>Pet Type Preference</label><br>
    <input type="radio" name="petType" value="dog" id="dog" />
    <label for="dog">Dog</label>
    <input type="radio" name="petType" value="cat" id="cat" />
    <label for="cat">Cat</label>
    <input type="radio" name="petType" value="any" id="any" checked />
    <label for="any">No preference</label><br><br>

    <label for="reason">Why do you want to adopt? *</label><br>
    <textarea id="reason" name="reason" rows="4" cols="50"
      placeholder="Tell us about your lifestyle and why you'd like to adopt a pet..." required></textarea><br><br>


    <h2>3. Suitability Evaluation</h2>

    <label>Do you have other pets at home?</label><br>
    <input type="radio" name="existingPets" value="yes" id="existingYes" />
    <label for="existingYes">Yes</label>
    <input type="radio" name="existingPets" value="no" id="existingNo" />
    <label for="existingNo">No</label><br><br>

    <label>Does anyone in your household have allergies?</label><br>
    <input type="radio" name="allergies" value="yes" id="allergyYes" />
    <label for="allergyYes">Yes</label>
    <input type="radio" name="allergies" value="no" id="allergyNo" />
    <label for="allergyNo">No</label><br><br>

    <label>Which of these can you commit to? (Select all that apply)</label><br>
    <input type="checkbox" name="commitments" value="vet_visits" id="vet" />
    <label for="vet">Regular vet visits</label><br>
    <input type="checkbox" name="commitments" value="exercise" id="exercise" />
    <label for="exercise">Daily exercise</label><br>
    <input type="checkbox" name="commitments" value="grooming" id="grooming" />
    <label for="grooming">Regular grooming</label><br>
    <input type="checkbox" name="commitments" value="training" id="training" />
    <label for="training">Basic training</label><br><br>


    <h2>4. Document Upload</h2>

    <label for="nricUpload">NRIC / Identification Document * (PDF, JPG, PNG — max 5MB)</label><br>
    <input type="file" id="nricUpload" name="nricDoc" accept=".pdf,.jpg,.jpeg,.png" required /><br><br>

    <label for="supportingDocs">Supporting Documents (Optional)</label><br>
    <input type="file" id="supportingDocs" name="supportingDocs" accept=".pdf,.jpg,.jpeg,.png" multiple /><br><br>


    <h2>5. Legal Agreement</h2>

    <p>
      By submitting this application, I confirm that all information provided is accurate and truthful.
      I understand that submitting false information may result in rejection of my application.
      I agree to provide a safe, loving, and permanent home for the adopted pet. I consent to a home
      visit or follow-up check by the organisation if deemed necessary. I acknowledge that the
      organisation reserves the right to decline any application without providing reasons. My personal
      data will be collected and used solely for the purposes of processing this adoption application,
      in accordance with the Personal Data Protection Act (PDPA) of Singapore.
    </p>

    <input type="checkbox" id="agreeTerms" name="agreeTerms" value="true" required />
    <label for="agreeTerms">I have read and agree to the terms and conditions above *</label><br><br>

    <button type="submit">Submit Application</button>

  </form>

</body>
</html>
