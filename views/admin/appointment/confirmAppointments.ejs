<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Assistance for Appointments</title>
</head>
<body>
    <%- include('../../navbar') %>

    <h1>Manage Appointments</h1>
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
        <div style="display:flex; gap:10px; align-items:center;">
            <select id="statusFilter" onchange="filterTable(this.value)">
                <option value="all">All</option>
                <option value="Pending Confirmation">Pending Confirmation</option>
                <option value="Appointment Confirmed!">Appointment Confirmed</option>
            </select>
            <form action="/admin/appointment/search" method="GET">
                <input type="text" name="user">
                <button type="submit">Search User</button>
            </form>
        </div>
        <button type="submit" form="confirmAppointments">Confirm Appointments</button>
    </div> <br>

    <form action="/admin/appointment/" method="POST" id="confirmAppointments">
        <table border="1">
            <tr>
                <th>User</th>
                <th>User Email</th>
                <th>Appointment Date</th>
                <th>Appointment Timeslot</th>
                <th>Seeing Pet Species</th>
                <th>Location</th>
                <th>Appointment Status</th>
                <th>Confirm Appointment?</th>
            </tr>
            <% for (let i=0; i < allAppointments.length; i ++) {%>
                <tr class="appointmentRow" data-status="<%= allAppointments[i].status %>">
                    <td><%=users_list[i].name%></td>
                    <td><%=users_list[i].email%></td>
                    <td><%= allAppointments[i].appointmentdate.toLocaleString('en-GB', {day: '2-digit',month: '2-digit',year: 'numeric'}) %></td>
                    <td><%= allAppointments[i].timeslot %></td>
                    <td><%= allAppointments[i].petspecies %></td>
                    <td><%= allAppointments[i].location %></td>
                    <td><%= allAppointments[i].status %></td>
                    <td><input type="checkbox" name="appointmentIds" value="<%= allAppointments[i]._id %>" <%=allAppointments[i].status === 'Appointment Confirmed!' ? 'disabled' : ''%>></td>
                </tr>
            <% } %>
        </table>
        <br>
    </form>
    <script>
        // script to filter based on status of the appointment - all / appointment confirmed / pending confirmation
        function filterTable(status) {
            const rows = document.querySelectorAll('.appointmentRow');
            rows.forEach(row => {
                if (status === 'all' || row.dataset.status === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>