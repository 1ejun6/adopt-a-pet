<!DOCTYPE html>
<html lang="en">
<head>
    <title>Manage Drive</title>
</head>
<body>
    <%- include('../../navbar') %>

    <h1>Manage Adoption Drives</h1>

    <a href="/admin/adoption-drives/create">create new drive</a>

    <% if (e) { %>
        <p><%= e %></p>
    <% } %>

    <% if (!drives || drives.length === 0) { %>
        <p>No adoption drives found.</p>
    <% } else { %>
        <% drives.forEach(drive => { %>
            <div style="border:1px solid black; padding:10px; margin-top:10px;">
                <p><strong>Title:</strong> <%= drive.title %></p>
                <p><strong>Location:</strong> <%= drive.location %></p>
                <p><strong>Date:</strong> <%= new Date(drive.eventdate).toDateString() %></p>
                <p><strong>Description:</strong> <%= drive.description || '' %></p>
                <p><strong>Capacity:</strong> <%= drive.attendees.length %> / <%= drive.mcapacity %></p>
                <p><strong>Status:</strong> <%= drive.status %></p>

                <a href="/admin/adoption-drives/<%= drive._id %>/edit">edit</a>

                <form action="/admin/adoption-drives/<%= drive._id %>/delete" method="post" style="display:inline;">
                    <button type="submit">delete</button>
                </form>
            </div>
        <% }) %>
    <% } %>
</body>
</html>