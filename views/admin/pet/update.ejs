<html>
<%- include('../../navbar') %>
    <% if (m) { %>
        <p style="color:green;">
            <%= m %>
        </p>
        <% } %>
            <% if (e) { %>
                <p style="color:red;">
                    <%= e %>
                </p>
                <% } %>
                    <h1>Update Pet</h1>
                    <form action="/admin/pet/update/<%= currentPet._id.toString() %>" method="POST">
                        <table border="1">
                            <tr>
                                <td><label>Name</label></td>
                                <td><input type="text" name="name" value="<%= currentPet.name %>" required></td>
                            </tr>

                            <tr>
                                <td><label for="species"><strong>Species</strong></label></td>
                                <td>
                                    <select id="species" name="species" required>
                                        <option value="" disabled>Select species</option>
                                        <option value="Dog" <% currentPet.species === "Dog" ? 'selected' : '' %>
                                                >Dog</option>
                                        <option value="Cat" <% currentPet.species === "Cat" ? 'selected' : '' %>
                                                >Cat</option>
                                        <option value="Rabbit" <% currentPet.species === "Rabbit" ? 'selected' : '' %>
                                                >Rabbit</option>
                                        <option value="Bird" <% currentPet.species === "Bird" ? 'selected' : '' %>
                                                >Bird</option>
                                        <option value="Hamster" <% currentPet.species === "Hamster" ? 'selected' : '' %>
                                                >Hamster</option>
                                        <option value="Other" <% currentPet.species === "Other" ? 'selected' : '' %>
                                                >Other</option>
                                    </select>
                                </td>
                            </tr>

                            <tr>
                                <td><label for="age"><strong>Age</strong></label></td>
                                <td>
                                    <input type="number" id="age" name="age" step="1" value=<%= currentPet.age %> required>
                                    <select name="ageUnit" required>
                                        <option value="year" <%= currentPet && currentPet.ageUnit.startsWith("year") ? 'selected' : '' %>>years old</option>
                                        <option value="month" <%= currentPet && currentPet.ageUnit.startsWith("month") ? ' selected' : '' %>>months old</option>
                                    </select>
                                </td>
                            </tr>

                            <tr>
                                <td><strong>Gender</strong></td>
                                <td>
                                    <label for="male">
                                        Male
                                        <input type="radio" id="male" name="gender" value="Male"
                                            <%=currentPet.gender==="Male" ? "checked" : "" %>>
                                    </label>
                                    <label for="female">
                                        Female
                                        <input type="radio" id="female" name="gender" value="Female"
                                            <%=currentPet.gender==="Female" ? "checked" : "" %>>
                                    </label>
                                </td>
                            </tr>

                            <tr>
                                <td><label>Weight</label></td>
                                <td><input type="number" name="weight" step="0.1" value="<%= currentPet.weight %>"
                                        required></td>
                            </tr>

                            <tr>
                                <td><label><strong>Health</strong></label></td>
                                <td>
                                    <% const healthOptions=[ "Vaccinated" , "Food Sensitivity" , "Neutered" , "Healthy"
                                        , "Has Health Conditions" ]; %>
                                        <% healthOptions.forEach(opt=> { %>
                                            <label>
                                                <input type="checkbox" name="health" value="<%= opt %>" <% if
                                                    (currentPet.health && currentPet.health.includes(opt)) { %> checked
                                                <% } %>
                                                    >
                                                    <%= opt %>
                                            </label><br>
                                            <% }) %>
                                </td>
                            </tr>

                            <tr>
                                <td><label>Status</label></td>
                                <td><input type="text" name="status" value="<%= currentPet.status %>" required></td>
                            </tr>

                            <tr>
                                <td><label>Description</label></td>
                                <td>
                                    <textarea name="description" rows="4"
                                        cols="40"><%= currentPet.description || '' %></textarea>
                                </td>
                            </tr>

                            <tr>
                                <td><label>Image URL</label></td>
                                <td><input type="text" name="imageURL" value="<%= currentPet.imageURL || '' %>"></td>
                            </tr>
                        </table>

                        <br>
                        <button type="submit">Save Changes</button>

                    </form>

                    <form action="/admin/pet" method="GET">
                        <button type="submit">Cancel</button>
                    </form>

</html>