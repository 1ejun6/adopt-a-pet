<!DOCTYPE html>
<html lang="en">

<head>
  <title>Update Adoption Application</title>
</head>

<body>
  <%- include('../../navbar') %>
  <% if (m) { %><p style="color:green;"><%= m %></p><% } %>
  <% if (e) { %><p style="color:red;"><%= e %></p><% } %>

  <% if (pet) { %>
  <div style="display:flex; align-items:center; gap:20px; margin-bottom:20px; padding:15px;">
    <% if (pet.imageURL) { %>
      <img src="<%= pet.imageURL %>" alt="<%= pet.name %>" style="width:150px; height:150px">
    <% } %>
    <div>
      <h2><%= pet.name %></h2>
      <p><%= pet.species %> | <%= pet.gender %> | <%= pet.age %> years old</p>
      <p><%= pet.description %></p>
    </div>
  </div>
  <% } %>

  <strong><u>Update Adoption Application</u></strong>

  <form action="/customer/adoption-application/edit/<%= adoptionapplication._id %>" method="POST">

    <label for="housingtype">Housing Type *</label><br>
    <select id="housingtype" name="housingtype" required>
      <option value="">Select your housing type</option>
      <option value="hdb" <%= adoptionapplication.housingtype === 'hdb' ? 'selected' : '' %>>HDB Flat</option>
      <option value="condo" <%= adoptionapplication.housingtype === 'condo' ? 'selected' : '' %>>Condominium</option>
      <option value="landed" <%= adoptionapplication.housingtype === 'landed' ? 'selected' : '' %>>Landed Property</option>
    </select><br><br>

    <label for="experience">Years of Experience with Pets *</label><br>
    <input type="number" id="experience" name="experience" min="0" value="<%= adoptionapplication.experience %>" required><br><br>

    <label for="reasonforadoption">Why do you want to adopt? *</label><br>
    <textarea id="reasonforadoption" name="reasonforadoption" rows="4" cols="50"
      placeholder="Tell us why you'd like to adopt a pet..." required><%= adoptionapplication.reasonforadoption %></textarea><br><br>

    <strong><u>Legal Agreement</u></strong>

      By submitting this adoption application, I confirm that all information provided is accurate and truthful.
      I understand that submitting false information may result in rejection of my adoption application.
      I agree to provide a safe, loving, and permanent home for the adopted pet. I consent to a home
      visit or follow-up check by the organisation if deemed necessary. I acknowledge that the
      organisation reserves the right to decline any adoption application without providing reasons. My personal
      data will be collected and used solely for the purposes of processing this adoption application,
      in accordance with the Personal Data Protection Act (PDPA) of Singapore.<br>

    <input type="checkbox" id="legalagreementaccepted" name="legalagreementaccepted" value="true" <%= adoptionapplication.legalagreementaccepted ? 'checked' : '' %> required />
    <label for="legalagreementaccepted">I have read and agree to the terms and conditions above *</label><br><br>
    <button type="submit">Save Changes</button>
    <a href="/customer/adoption-application">Cancel</a>

  </form>
</body>

</html>
