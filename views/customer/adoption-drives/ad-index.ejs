<!--index page for customers to view upcoming drives-->
<!DOCTYPE html>
<html lang="en">
<head>
  <title>Customer Adoption Drives</title>
</head>

<body>
  <%- include('../../navbar') %>

  <h1>Upcoming Adoption Drives</h1>

  <% if (msg) { %>
    <p class="msg <%= (msg === 'success') ? 'success' : 'error' %>">
      <% if (msg === 'success') { %>
        RSVP successful!
      <% } else if (msg === 'unrsvp') { %>
        You have successfully cancelled your RSVP.
      <% } else if (msg === 'cancelled') { %>
        Sorry, this adoption drive has been cancelled.
      <% } else if (msg === 'closed') { %>
        RSVP closed — this drive is full.
      <% } else { %>
        Could not RSVP. Please try again.
      <% } %>
    </p>
  <% } %>
  

  <table border="1" cellpadding="10" cellspacing="0">
    <thead>
      <tr>
        <th>Title</th>
        <th>Location</th>
        <th>Date</th>
        <th>Description</th>
        <th>Capacity</th>
        <th>RSVP</th>
      </tr>
    </thead>
    <tbody>
      <% drives.forEach(drive => { %>
        <tr>
          <td><%= drive.title %></td>
          <td><%= drive.location %></td>
          <td><%= drive.eventdate.toDateString() %></td>
          <td><%= drive.description %></td>
          <td><%= drive.attendees.length %> / <%= drive.mcapacity %></td>
          <td>
            <% if (drive.status === 'open') { %>
              <% if (drive.attendees.some(attendee => attendee.toString() === currentuser.id.toString())) { %>
                <form action="/adoption-drives/<%= drive._id %>/unrsvp" method="post">
                  <button type="submit">Un-RSVP</button>
                </form>
              <% } else { %>
                <form action="/adoption-drives/<%= drive._id %>/rsvp" method="post">
                  <button type="submit">RSVP</button>
                </form>
              <% } %>
            <% } else if (drive.status === 'closed') { %>
              <% if (drive.attendees.some(attendee => attendee.toString() === currentuser.id.toString())) { %>
                <form action="/adoption-drives/<%= drive._id %>/unrsvp" method="post">
                  <button type="submit">Un-RSVP</button>
                </form>
              <% } else { %>
                Closed
              <% } %>
            <% } else if (drive.status === 'cancelled') { %>
              Cancelled
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</body>
</html>