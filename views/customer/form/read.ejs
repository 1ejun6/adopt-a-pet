<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Submitted Application</title>
</head>
<body>
    <%- include('../../navbar') %>
    <% if (msg === 'submitted') { %>
    <p style="color:green;">Submission successful!</p>
    <% } %>

    <h1>Your Applications</h1>

    <% user.forEach(function(application) { %>
        <hr>
        <p>Reference ID: <%= application._id %></p>
        <p><strong>Housing Type:</strong> <%= application.housingtype %></p>
        <p><strong>Experience:</strong> <%= application.experience %></p>
        <p><strong>Reason for Adopting:</strong> <%= application.reasonforadoption %></p>
        <p><strong>Agreed to Terms:</strong> <%= application.legalagreementaccepted ? 'Yes' : 'No' %></p>
        <p>Submitted on: <%= new Date(application.cdate).toDateString() %></p>

        <a href="/adoption/update?id=<%= application._id %>">Update</a>

        <form action="/adoption/<%= application._id %>/delete" method="POST" style="display:inline;"
            onsubmit="return confirm('Are you sure you want to delete this application?');">
            <button type="submit">Delete</button>
        </form>
    <% }) %>

</body>
</html>


