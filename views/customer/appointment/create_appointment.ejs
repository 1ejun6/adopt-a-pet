<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create an Appointment</title>
</head>
<body>
    <%- include('../../navbar') %>
    <h3>Book an Appointment to see your favourite animals!</h3>
    <form action="/customer/appointment/create" method="POST">
        Select a date (Book 3 days in advance): <input name="appointmentDate" type="date" id="appointmentDate" required> <br>
        Select a time slot: 
        <select required name="timeslot">
            <option value="1100">1100</option>
            <option value="1300">1300</option>
            <option value="1400">1400</option>
            <option value="1500">1500</option>
            <option value="1600">1600</option>
            <option value="1700">1700</option>
        </select> <br>
        Select a location: 
        <select required name="location">
            <option value="" disabled selected>-- Select a Location --</option>
            <option value="Suntec">Suntec</option>
            <option value="Tampines">Tampines</option>
            <option value="Jurong East">Jurong East</option>
        </select> <br>
        Select a pet species you would like to see:
        <select required name="petspecies" id="petspecies" onchange="fetchPets(this.value)">
            <option value="" disabled selected>-- Select a Pet Species --</option>
            <% for (species of pet_species_list) {%>
                <option value="<%=species%>"><%=species%></option>
            <% } %>
        </select> <br>
        <div id="petTableContainer" style="display:none; margin-top:10px;">
            <table border="1">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Species</th>
                        <th>Age</th>
                        <th>Weight</th>
                        <th>Health</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Photo</th>
                    </tr>
                </thead>
                <tbody id="petTableBody"></tbody>
            </table>
        </div>
        <button type="submit">Book Appointment</button>
    </form>
    <script>
        async function fetchPets(species) {
            if (!species) {
                document.getElementById('petTableContainer').style.display = 'none';
                return;
            }

            const response = await fetch('/customer/appointment/pets?species=' + species);

            if (!response.ok) {
                alert('Error fetching pets.');
                return;
            }

            const pets = await response.json();
            const tbody = document.getElementById('petTableBody');
            tbody.innerHTML = '';

            if (pets.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7">No pets found.</td></tr>';
            } else {
                pets.forEach(pet => {
                    const row = `<tr>
                        <td>${pet.name}</td>
                        <td>${pet.species}</td>
                        <td>${pet.age} ${pet.ageUnit}</td>
                        <td>${pet.weight}</td>
                        <td>${pet.health}</td>
                        <td>${pet.status}</td>
                        <td>${pet.description}</td>
                        <td><img src="${pet.imageURL}" style="width:130px; height:100px"></td>

                    </tr>`;
                    tbody.innerHTML += row;
                });
            }
            document.getElementById('petTableContainer').style.display = 'block';
        }

    document.addEventListener('DOMContentLoaded', function() {
        const today = new Date();
        today.setDate(today.getDate() + 3);
        const minDate = today.toISOString().split('T')[0];
        document.getElementById('appointmentDate').min = minDate;
    });
    </script>
</body>
</html>