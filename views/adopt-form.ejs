<!DOCTYPE html>
<html lang="en">

<head>
  <title>Pet Adoption Application</title>
</head>

<body>
  <%- include('navbar') %>
  <% if (m) { %><p style="color:green;"><%= m %></p><% } %>
  <% if (e) { %><p style="color:red;"><%= e %></p><% } %>
  
  <h1>Pet Adoption Application</h1>

  <% if (typeof successMsg !== 'undefined' && successMsg) { %>
    <p><%= successMsg %></p>
  <% } %>
  <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
    <p><%= errorMsg %></p>
  <% } %>

  <form action="<%= user && user.userid ? '/adoption/updateform' : '/adoption/apply' %>" method="POST">

    <h2>1. Applicant's Information</h2>

    <!--if user is not undefined, return user.fullName. else, return empty string-->
    <label for="fullName">Full Name *</label><br>
    <input type="text" id="fullName" name="fullName"
      placeholder="e.g. Jane Tan" required value="<%= typeof user !== 'undefined' && user ? user.fullName : '' %>"/><br><br>

    <label for="email">Email Address *</label><br>
    <input type="email" id="email" name="email"
      placeholder="jane@email.com" required value="<%= typeof user !== 'undefined' && user ? user.email : '' %>"/><br><br>

    <label for="phone">Phone Number *</label><br>
    <input type="tel" id="phone" name="phone"
      placeholder="+65 9123 4567" required value="<%= typeof user !== 'undefined' && user ? user.phone : '' %>"/><br><br>

    <label for="age">Age *</label><br>
    <input type="number" id="age" name="age" min="18" max="99"
      placeholder="21" required value="<%= typeof user !== 'undefined' && user ? user.age : '' %>"/><br><br>

    <label for="address">Home Address *</label><br>
    <input type="text" id="address" name="address"
      placeholder="Block 12, Ang Mo Kio Ave 3, #05-22" required value="<%= typeof user !== 'undefined' && user ? user.address : '' %>"/><br><br>

    <label for="housingType">Housing Type *</label><br>
    <select id="housingType" name="housingType" required>
      <option value="">Select your housing type</option> <!--should i use <option value="" hidden selected>? -->
      <option value="hdb" <%= (typeof user !== 'undefined' && user && user.housingType === 'hdb') ? 'selected' : '' %>>HDB Flat</option>
      <option value="condo" <%= (typeof user !== 'undefined' && user && user.housingType === 'condo') ? 'selected' : '' %>>Condominium</option>
      <option value="landed" <%= (typeof user !== 'undefined' && user && user.housingType === 'landed') ? 'selected' : '' %>>Landed Property</option>
      <option value="other" <%= (typeof user !== 'undefined' && user && user.housingType === 'other') ? 'selected' : '' %>>Other</option>
    </select><br><br>


    <h2>2. Pet Preference</h2>
    <label>Pet Type Preference</label><br>
    <input type="radio" name="petType" value="dog" id="dog" <%= (typeof user !== 'undefined' && user && user.petType === 'dog') ? 'checked' : '' %> />
    <label for="dog">Dog</label>
    <input type="radio" name="petType" value="cat" id="cat" <%= (typeof user !== 'undefined' && user && user.petType === 'cat') ? 'checked' : '' %> />
    <label for="cat">Cat</label>
    <input type="radio" name="petType" value="any" id="any" <%= (typeof user !== 'undefined' && user && user.petType === 'any') ? 'checked' : '' %> />
    <label for="any">No preference</label><br><br>

    <label for="reason">Why do you want to adopt? *</label><br>
    <textarea id="reason" name="reason" rows="4" cols="50"
      placeholder="Tell us about your lifestyle and why you'd like to adopt a pet..." required><%= typeof user !== 'undefined' && user ? user.reason : '' %></textarea>

    <h2>3. Suitability Evaluation</h2>

    <label>Do you have other pets at home?</label><br>
    <input type="radio" name="existingPets" value="yes" id="existingYes" <%= (typeof user !== 'undefined' && user && user.existingPets === 'yes') ? 'checked' : '' %> />
    <label for="existingYes">Yes</label>
    <input type="radio" name="existingPets" value="no" id="existingNo" <%= (typeof user !== 'undefined' && user && user.existingPets === 'no') ? 'checked' : '' %> />
    <label for="existingNo">No</label><br><br>

    <label>Does anyone in your household have allergies?</label><br>
    <input type="radio" name="allergies" value="yes" id="allergyYes" <%= (typeof user !== 'undefined' && user && user.allergies === 'yes') ? 'checked' : '' %> />
    <label for="allergyYes">Yes</label>
    <input type="radio" name="allergies" value="no" id="allergyNo" <%= (typeof user !== 'undefined' && user && user.allergies === 'no') ? 'checked' : '' %> />
    <label for="allergyNo">No</label><br><br>

    <label>Which of these can you commit to? (Select all that apply)</label><br>
    <input type="checkbox" name="commitments" value="vet_visits" id="vet" <%= (typeof user !== 'undefined' && user && user.commitments && user.commitments.includes('vet_visits')) ? 'checked' : '' %> />
    <label for="vet">Regular vet visits</label><br>
    <input type="checkbox" name="commitments" value="exercise" id="exercise" <%= (typeof user !== 'undefined' && user && user.commitments && user.commitments.includes('exercise')) ? 'checked' : '' %> />
    <label for="exercise">Daily exercise</label><br>
    <input type="checkbox" name="commitments" value="grooming" id="grooming" <%= (typeof user !== 'undefined' && user && user.commitments && user.commitments.includes('grooming')) ? 'checked' : '' %> />
    <label for="grooming">Regular grooming</label><br>
    <input type="checkbox" name="commitments" value="training" id="training" <%= (typeof user !== 'undefined' && user && user.commitments && user.commitments.includes('training')) ? 'checked' : '' %> />
    <label for="training">Basic training</label><br><br>


    <h2>4. Document Upload</h2>

    <label for="nricUpload">NRIC / Identification Document * (PDF, JPG, PNG — max 5MB)</label><br>
    <input type="file" id="nricUpload" name="nricDoc" /><br><br> <!-- should i include accept=".pdf,.jpg,.jpeg,.png" multiple-->

    <label for="supportingDocs">Supporting Documents (Optional)</label><br> 
    <input type="file" id="supportingDocs" name="supportingDocs" /><br><br> <!-- accept=".pdf,.jpg,.jpeg,.png" multiple -->


    <h2>5. Legal Agreement</h2>

    <p>
      By submitting this application, I confirm that all information provided is accurate and truthful.
      I understand that submitting false information may result in rejection of my application.
      I agree to provide a safe, loving, and permanent home for the adopted pet. I consent to a home
      visit or follow-up check by the organisation if deemed necessary. I acknowledge that the
      organisation reserves the right to decline any application without providing reasons. My personal
      data will be collected and used solely for the purposes of processing this adoption application,
      in accordance with the Personal Data Protection Act (PDPA) of Singapore.
    </p>

    <input type="checkbox" id="agreeTerms" name="agreeTerms" value="true" <%= (typeof user !== 'undefined' && user && user.agreeTerms) ? 'checked' : '' %> required />
    <label for="agreeTerms">I have read and agree to the terms and conditions above *</label><br><br>
    <button type="submit">Submit Application</button>

  </form>
</body>

</html>