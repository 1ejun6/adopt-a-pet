<!DOCTYPE html>
<html lang="en">

<head>
  <title>login</title>
</head>

<body>
  <%- include('navbar') %>
  <% if (m) { %><p style="color:green;"><%= m %></p><% } %>
  <% if (e) { %><p style="color:red;"><%= e %></p><% } %>
  <form action="/login" method="post">
    <div>
      <label>email</label>
      <input type="email" name="email" required>
    </div>
    <div>
      <label>password</label>
      <input type="password" name="password" required>
    </div>
    <button type="submit">login</button>
  </form>
</body>

</html>