<%const user = currentuser || null;%>
<nav aria-label="main" style="display:flex; justify-content:space-between; align-items:center; gap:16px; padding:8px 0 16px 0;">
  <div style="display:flex; align-items:center; gap:12px;">
    <% if (!user) { %>
      <a href="/">adopt a pet</a>

    <% } %>

    <% if (user && user.role === 'admin') { %>
      <a href="/admin">home</a>
      <a href="/admin/user">admins</a>
      <a href="/admin/adoption-drives">adoption drives</a>
      <a href="/admin/pet">pet listings</a>
      <a href="/admin/adoption-application">adoption applications</a>
    <% } else if (user && user.role === 'customer') { %>
      <a href="/customer">home</a>
      <a href="/customer/adoption-drives">adoption drives</a>
      <a href="/customer/pet">adopt a pet</a>
      <a href="/customer/adoption-application">adoption applications</a>
    <% } %>
  </div>

  <div style="display:flex; align-items:center; gap:12px;">
    <% if (user) { %>
      <% if (user.role === 'customer') { %>
        <a href="/customer/user/read"><%= user.email %></a>
<% } else { %>
  <span><%= user.email %></span>
<% } %>
        <a href="/logout">logout</a>
    <% } else { %>
      <a href="/login">login</a>
      <a href="/register">register</a>
      
    <% } %>
  </div>
</nav>
